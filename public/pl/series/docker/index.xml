tabContents[i].style.display = 'none';
if (0 === parseInt(i, 10) &amp;&amp; !tabContents[i].classList.contains('active')) {
tabContents[i].classList.add('active');
}
}
for (var i = 0; i &lt; tabLinks.length; i++) {
